{
  "$defs": {
    "BusConfig": {
      "description": "バス単位の同時アクセス制限",
      "properties": {
        "max_concurrency": {
          "default": 1,
          "title": "Max Concurrency",
          "type": "integer"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "title": "BusConfig",
      "type": "object"
    },
    "ExperimentUnit": {
      "description": "1 つの実験対象に紐づく機器セット (map_recipe の bindings に展開)\n\n例:\n  unit001:\n    psu: psu001\n    temp: temp001\n    dmm: dmm001",
      "properties": {
        "bindings": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Bindings",
          "type": "object"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "title": "ExperimentUnit",
      "type": "object"
    },
    "InstrumentBinding": {
      "description": "logical alias → resource_name のバインディング + 物理 bus 帰属",
      "properties": {
        "resource": {
          "title": "Resource",
          "type": "string"
        },
        "bus": {
          "default": "",
          "title": "Bus",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "resource"
      ],
      "title": "InstrumentBinding",
      "type": "object"
    },
    "InstrumentGroup": {
      "description": "同種機器の集合 (start_group_query_job の対象)",
      "properties": {
        "members": {
          "items": {
            "type": "string"
          },
          "title": "Members",
          "type": "array"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "title": "InstrumentGroup",
      "type": "object"
    }
  },
  "description": "system_config root (PREVIEW: v1.0 で正式公開予定。外部利用は VS Code 補完等の参考用途のみ。)",
  "properties": {
    "instruments": {
      "additionalProperties": {
        "$ref": "#/$defs/InstrumentBinding"
      },
      "title": "Instruments",
      "type": "object"
    },
    "buses": {
      "additionalProperties": {
        "$ref": "#/$defs/BusConfig"
      },
      "title": "Buses",
      "type": "object"
    },
    "instrument_groups": {
      "additionalProperties": {
        "$ref": "#/$defs/InstrumentGroup"
      },
      "title": "Instrument Groups",
      "type": "object"
    },
    "experiment_units": {
      "additionalProperties": {
        "$ref": "#/$defs/ExperimentUnit"
      },
      "title": "Experiment Units",
      "type": "object"
    }
  },
  "title": "System Configuration (_system.yaml) (v0.8 preview)",
  "type": "object",
  "$id": "https://tectos-jp.github.io/visa-mcp/schemas/system_config.schema.preview.json",
  "x-visa-mcp-status": "preview",
  "x-compatibility": "subject-to-change-before-v1.0"
}
